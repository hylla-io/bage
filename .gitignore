# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Go build outputs / test binaries
/bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.txt

# Go workspace files (machine-local, never committed)
go.work
go.work.sum

# Agent / tool state — track project-level config (.claude/agents/*.md +
# .claude/settings.json + .claude/hooks/) so subagent personas + tool
# allowlists travel with the repo. Per-machine variants stay ignored.
.claude/*.local.json
.claude/sessions/
.claude/agent-runs/
.claude/hooks/ta_gate_debug.log
.claude/hooks/agent_audit_errors.log

# ta runtime state — track only the schema + bundled agents/config; runtime
# DBs, logs, and cascade scratch stay ignored.
.ta/*
!.ta/schema.toml

# Editor / IDE cruft
.vscode/
.idea/
.zed/
.fleet/
.vs/
*.swp
*.swo
*.bak

# Logs
*.log

# Secrets — never commit credentials or local env
.env
.env.*
*.env
*.pem
*.key
*.p12
*.pfx
graphify-out/

# E2E dogfood scratch — local-only test tree, never committed
e2e-scratch/

# Rust build artifacts
/target/
/rust/

# Private security roadmap — local only, never committed (public repo)
/HARDENING.md
